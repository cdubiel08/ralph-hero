# Git worktrees (created by scripts/create-worktree.sh)
worktrees/

# Knowledge DB (lives at ~/.ralph-hero/knowledge.db)
knowledge.db

# Obsidian
thoughts/.obsidian/
thoughts/Untitled*.canvas

# Generated knowledge index (rebuilt by ralph-knowledge:setup)
thoughts/_*.md
thoughts/_issues/

# Local-only files (secrets, tokens, config)
*.local.md
*.local.json
.env
.env.*

# Playwright CLI session data (ephemeral screenshots/snapshots)
.playwright-cli/
