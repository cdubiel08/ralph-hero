# Browse and run a recipe interactively (falls back to --list without fzf)
default:
    #!/usr/bin/env bash
    if command -v fzf >/dev/null 2>&1; then
        just --choose
    else
        just --list
    fi

# Triage a backlog issue - assess validity, close duplicates, route to research
[group('workflow')]
triage *args:
    #!/usr/bin/env bash
    set -eu
    source "{{justfile_directory()}}/scripts/cli-dispatch.sh"
    DEFAULT_BUDGET=1.00 DEFAULT_TIMEOUT=15m
    _args={{quote(args)}}
    set -- $_args
    dispatch "ralph-triage" "$@"

