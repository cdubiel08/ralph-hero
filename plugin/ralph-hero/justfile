team issue="" budget="10.00" timeout="30m":
    RALPH_BUDGET="{{budget}}" TIMEOUT="{{timeout}}" "{{justfile_directory()}}"/scripts/ralph-team-loop.sh {{issue}}

# Tree-expansion orchestrator - drives issue through full lifecycle
